STA JUMP_TARGET
INY
LDA (TMP_ZP),Y
STA JUMP_TARGET+1
RTS
STEPZERO	PLA				; step 0
JMP LOOPING2
EXITLOOP	LDA TMP2_REG
STA FORSTACKP
