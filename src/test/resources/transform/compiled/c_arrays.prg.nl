INITVARS
JSR INITSTRVARS
LDA #0
LDY #4
REALINITLOOP0:
STA VAR_TI,Y
STA VAR_T0,Y
STA VAR_X,Y
STA VAR_Y,Y
STA VAR_I,Y
DEY
BMI REALLOOPEXIT0
JMP REALINITLOOP0
REALLOOPEXIT0:
LDA #<VAR_A[]
LDY #>VAR_A[]
JSR INITSPARAMS
JSR INITNARRAY
LDA #0
STA VAR_X%
STA VAR_X%+1
STA VAR_Y%
STA VAR_Y%+1
LDA #<VAR_A%[]
LDY #>VAR_A%[]
JSR INITSPARAMS
JSR INITNARRAY
LDA #<VAR_AI%[]
LDY #>VAR_AI%[]
JSR INITSPARAMS
JSR INITNARRAY
LDA #<VAR_FA%[]
LDY #>VAR_FA%[]
JSR INITSPARAMS
JSR INITNARRAY
LDA #0
RTS
