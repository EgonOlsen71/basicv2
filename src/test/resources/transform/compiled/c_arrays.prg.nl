JSR STROUTWL
; Optimizer rule: Memory saving STROUT/1
LDA #<VAR_T0
LDY #>VAR_T0
JSR COPY2_XYA_YREG
; Optimizer rule: MEM 2 Y_REG/3
; Optimizer rule: Memory saving copy/4
