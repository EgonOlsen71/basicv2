8237	.$3baf	CONST_124 .BYTE 12
8238	.$3bb0	.STRG "fre(0);ti/60"
8240	.$3bbc	CONST_125 .BYTE 41
8241	.$3bbd	.STRG "{down}Allein der FRE-Befehl benoetigt ca."
8243	.$3be1	CONST_126 .BYTE 33
8244	.$3be2	.STRG "339 Sekunden, da er eine Garbage-"
8246	.$3c03	CONST_127 .BYTE 20
