8270	.$3ca2	CONST_135 .BYTE 45
8271	.$3ca3	.STRG "{down}in diesem Fall etwa 680 mal schneller !"
8273	.$3ccb	CONST_136 .BYTE 49
8274	.$3ccc	.STRG "{clear}{down*2}Die Leistungsdaten des Basic-Boss:"
8276	.$3cf1	CONST_137 .BYTE 23
8277	.$3cf2	.STRG "{down}- kurze Compilate"
