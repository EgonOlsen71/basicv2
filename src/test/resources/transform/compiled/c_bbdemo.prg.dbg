8192	.$3999	CONST_102 .BYTE 40
8193	.$399a	.STRG "{down}Das Basicprogramm zeigt auch, dass"
8195	.$39bd	CONST_103 .BYTE 37
8196	.$39be	.STRG "der Programmierer alle Moeglichkeiten"
8198	.$39e3	CONST_104 .BYTE 38
