8174	.$393b	.STRG "1"
8176	.$393c	CONST_99 .BYTE 48
8177	.$393d	.STRG "{clear}{down*2}Sie sollten zum Vergleich mal die"
8179	.$3961	CONST_100 .BYTE 30
8180	.$3962	.STRG "Basic-Version dieses Programms"
8182	.$3980	CONST_101 .BYTE 17
8183	.$3981	.STRG "ablaufen lassen !"
8185	.$3992	CONST_102 .BYTE 40
8186	.$3993	.STRG "{down}Das Basicprogramm zeigt auch, dass"
8188	.$39b6	CONST_103 .BYTE 37
8189	.$39b7	.STRG "der Programmierer alle Moeglichkeiten"
8191	.$39dc	CONST_104 .BYTE 38
8192	.$39dd	.STRG "von Basic ausreizen kann, ohne dass er"
8194	.$3a03	CONST_105 .BYTE 29
8195	.$3a04	.STRG "unnoetig eingeschraenkt wird."
8197	.$3a21	CONST_106 .BYTE 37
8198	.$3a22	.STRG "{down}Denn ausser solchen Bildschirm-"
8200	.$3a42	CONST_107 .BYTE 34
8201	.$3a43	.STRG "spielereien kann man auch ernstere"
8203	.$3a65	CONST_108 .BYTE 33
8204	.$3a66	.STRG "Anwendungen programmieren, da der"
8206	.$3a87	CONST_109 .BYTE 31
8207	.$3a88	.STRG "Basic-Boss z.B. eine wesentlich"
8209	.$3aa7	CONST_110 .BYTE 35
8210	.$3aa8	.STRG "leistungsfaehigere Stringverwaltung"
8212	.$3acb	CONST_111 .BYTE 39
8213	.$3acc	.STRG "besitzt als der Basicinterpreter. Darum"
8215	.$3af3	CONST_112 .BYTE 35
8216	.$3af4	.STRG "ist nun auch die Garbage-Collection"
8218	.$3b17	CONST_113 .BYTE 21
8219	.$3b18	.STRG "um einiges schneller."
8221	.$3b2d	CONST_114 .BYTE 40
8222	.$3b2e	.STRG "{clear}Was das heisst, werden Sie merken"
8224	.$3b50	CONST_115 .BYTE 36
8225	.$3b51	.STRG "wenn Sie folgendes Programm ablaufen"
8227	.$3b75	CONST_116 .BYTE 13
8228	.$3b76	.STRG "lassen:{down}"
