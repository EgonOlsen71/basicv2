8157	.$391a	.STRG "4"
8159	.$391b	CONST_98 .BYTE 1
8160	.$391c	.STRG "1"
8162	.$391d	CONST_99 .BYTE 48
8163	.$391e	.STRG "{clear}{down*2}Sie sollten zum Vergleich mal die"
8165	.$3942	CONST_100 .BYTE 30
8166	.$3943	.STRG "Basic-Version dieses Programms"
8168	.$3961	CONST_101 .BYTE 17
8169	.$3962	.STRG "ablaufen lassen !"
8171	.$3973	CONST_102 .BYTE 40
8172	.$3974	.STRG "{down}Das Basicprogramm zeigt auch, dass"
8174	.$3997	CONST_103 .BYTE 37
8175	.$3998	.STRG "der Programmierer alle Moeglichkeiten"
8177	.$39bd	CONST_104 .BYTE 38
8178	.$39be	.STRG "von Basic ausreizen kann, ohne dass er"
8180	.$39e4	CONST_105 .BYTE 29
8181	.$39e5	.STRG "unnoetig eingeschraenkt wird."
8183	.$3a02	CONST_106 .BYTE 37
8184	.$3a03	.STRG "{down}Denn ausser solchen Bildschirm-"
8186	.$3a23	CONST_107 .BYTE 34
8187	.$3a24	.STRG "spielereien kann man auch ernstere"
8189	.$3a46	CONST_108 .BYTE 33
8190	.$3a47	.STRG "Anwendungen programmieren, da der"
8192	.$3a68	CONST_109 .BYTE 31
8193	.$3a69	.STRG "Basic-Boss z.B. eine wesentlich"
8195	.$3a88	CONST_110 .BYTE 35
8196	.$3a89	.STRG "leistungsfaehigere Stringverwaltung"
8198	.$3aac	CONST_111 .BYTE 39
8199	.$3aad	.STRG "besitzt als der Basicinterpreter. Darum"
8201	.$3ad4	CONST_112 .BYTE 35
8202	.$3ad5	.STRG "ist nun auch die Garbage-Collection"
8204	.$3af8	CONST_113 .BYTE 21
8205	.$3af9	.STRG "um einiges schneller."
8207	.$3b0e	CONST_114 .BYTE 40
8208	.$3b0f	.STRG "{clear}Was das heisst, werden Sie merken"
8210	.$3b31	CONST_115 .BYTE 36
8211	.$3b32	.STRG "wenn Sie folgendes Programm ablaufen"
8213	.$3b56	CONST_116 .BYTE 13
8214	.$3b57	.STRG "lassen:{down}"
