8201	.$3a0a	CONST_105 .BYTE 29
8202	.$3a0b	.STRG "unnoetig eingeschraenkt wird."
8204	.$3a28	CONST_106 .BYTE 37
8205	.$3a29	.STRG "{down}Denn ausser solchen Bildschirm-"
8207	.$3a49	CONST_107 .BYTE 34
8208	.$3a4a	.STRG "spielereien kann man auch ernstere"
8210	.$3a6c	CONST_108 .BYTE 33
8211	.$3a6d	.STRG "Anwendungen programmieren, da der"
8213	.$3a8e	CONST_109 .BYTE 31
8214	.$3a8f	.STRG "Basic-Boss z.B. eine wesentlich"
8216	.$3aae	CONST_110 .BYTE 35
8217	.$3aaf	.STRG "leistungsfaehigere Stringverwaltung"
8219	.$3ad2	CONST_111 .BYTE 39
8220	.$3ad3	.STRG "besitzt als der Basicinterpreter. Darum"
