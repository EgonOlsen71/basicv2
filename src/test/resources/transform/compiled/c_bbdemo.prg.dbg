8148	.$38da	.STRG "{space*3}3...Hintergrunddemo"
8150	.$38f0	CONST_95 .BYTE 21
8151	.$38f1	.STRG "{space*3}4...Noch was"
8153	.$3900	CONST_96 .BYTE 30
8154	.$3901	.STRG "{down*2}(Thilo Herrmann, 1988)"
